# Loopback bind so nginx is the only public entrypoint.
LECREV_API_ADDR=127.0.0.1:8080
LECREV_COORDINATOR_BASE_PORT=9091

# Bootstrap dashboard/API key.
LECREV_BOOTSTRAP_ADMIN_API_KEY=replace-me
LECREV_SECRETS_PROXY_TOKEN=replace-me

# APAC-only execution topology.
LECREV_EXECUTION_REGIONS=ap-south-1,ap-south-2,ap-southeast-1

# Local infra services on the EC2 host.
LECREV_POSTGRES_DSN=postgres://lecrev:replace-me@127.0.0.1:5432/lecrev?sslmode=disable
LECREV_NATS_URL=nats://127.0.0.1:4222

# AWS integrations.
LECREV_S3_REGION=ap-south-1
LECREV_S3_BUCKET=lecrev-artifacts-276307603042-ap-south-1
LECREV_SECRETS_BACKEND=aws-secrets-manager
LECREV_AWS_REGION=ap-south-1

# Safer local control-plane transport.
LECREV_ENABLE_MTLS=true

# Default demo execution path on the EC2 host. Switch to "firecracker"
# after you provision Firecracker, kernel, and guest rootfs assets.
LECREV_EXECUTION_DRIVER=local-node
LECREV_EXECUTION_HOST_SLOTS=1

# Optional Firecracker execution settings.
# LECREV_EXECUTION_DRIVER=firecracker
# LECREV_FIRECRACKER_BINARY=/usr/local/bin/firecracker
# LECREV_JAILER_BINARY=/usr/local/bin/jailer
# This one-box deployment runs the full stack as the unprivileged "lecrev" user,
# so keep jailer disabled here unless you split the execution host into its own
# privileged service.
# LECREV_FIRECRACKER_USE_JAILER=false
# LECREV_FIRECRACKER_KERNEL_IMAGE=/var/lib/lecrev/vmlinux
# LECREV_FIRECRACKER_ROOTFS=/var/lib/lecrev/rootfs.ext4
# LECREV_FIRECRACKER_WORKSPACE_DIR=/var/lib/lecrev/runtime
# LECREV_FIRECRACKER_SNAPSHOT_DIR=/var/lib/lecrev/runtime/snapshots
# Deploys rebuild the guest rootfs from the host node binary and the uploaded
# /opt/lecrev/bin/lecrev-guest-runner, and place the guest runner at this path
# inside the guest filesystem.
# LECREV_FIRECRACKER_GUEST_INIT=/usr/local/bin/lecrev-guest-runner
# When using the static tap helper, keep execution host slots at 1.
# LECREV_FIRECRACKER_TAP_DEVICE=tap0
# LECREV_FIRECRACKER_GUEST_MAC=06:00:ac:10:00:02
# LECREV_FIRECRACKER_GUEST_IP=172.16.0.2
# LECREV_FIRECRACKER_GATEWAY_IP=172.16.0.1
# LECREV_FIRECRACKER_NETMASK=255.255.255.252
