AUTH_PORT=3001
BETTER_AUTH_URL=https://lecrev.everything-assistant.com
VITE_BETTER_AUTH_URL=https://lecrev.everything-assistant.com/api/auth
BETTER_AUTH_TRUSTED_ORIGINS=https://lecrev.everything-assistant.com,https://api.lecrev.everything-assistant.com,https://functions.lecrev.everything-assistant.com
BETTER_AUTH_SECRET=replace-this-with-a-long-random-secret
BETTER_AUTH_DB_PATH=/var/lib/lecrev/frontend-auth/better-auth.sqlite
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=/etc/lecrev/frontend-auth/github-app.private-key.pem
LECREV_POSTGRES_DSN=postgres://lecrev:replace-me@127.0.0.1:5432/lecrev?sslmode=disable
LECREV_API_TARGET=http://127.0.0.1:8080
VITE_LECREV_API_BASE_URL=
