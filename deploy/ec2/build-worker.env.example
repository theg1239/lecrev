# Shared metadata and queue backends.
LECREV_POSTGRES_DSN=postgres://lecrev:replace-me@10.0.0.10:5432/lecrev?sslmode=disable
LECREV_NATS_URL=nats://10.0.0.10:4222

# Execution regions whose build queues this worker should consume.
LECREV_EXECUTION_REGIONS=ap-south-1,ap-south-2,ap-southeast-1
LECREV_BUILD_WORKERS_PER_REGION=4
LECREV_BUILD_GIT_CLONE_TIMEOUT_SEC=180
LECREV_BUILD_NPM_INSTALL_TIMEOUT_SEC=480
LECREV_BUILD_NPM_BUILD_TIMEOUT_SEC=600
LECREV_BUILD_NPM_PRUNE_TIMEOUT_SEC=180

# Artifact storage used for immutable bundles and startup manifests.
LECREV_S3_REGION=ap-south-1
LECREV_S3_BUCKET=lecrev-artifacts-276307603042-ap-south-1
LECREV_S3_REGION_BUCKETS=ap-south-1:lecrev-artifacts-276307603042-ap-south-1,ap-south-2:lecrev-artifacts-276307603042-ap-south-2,ap-southeast-1:lecrev-artifacts-276307603042-ap-southeast-1

# Optional explicit credentials. Leave empty when using an instance profile.
LECREV_S3_ENDPOINT=
LECREV_S3_ACCESS_KEY=
LECREV_S3_SECRET_KEY=
