# Node-agent identity and control-plane connectivity.
LECREV_NODE_AGENT_HOST_ID=host-ap-south-1-a
LECREV_NODE_AGENT_REGION=ap-south-1
LECREV_COORDINATOR_ADDR=10.0.0.10:9091
LECREV_CONTROL_PLANE_BASE_URL=http://10.0.0.10:8080
LECREV_SECRETS_PROXY_TOKEN=replace-me

# Artifact storage reachable from the execution host.
# Set this bucket to the regional bucket that matches LECREV_NODE_AGENT_REGION.
LECREV_S3_REGION=ap-south-1
LECREV_S3_BUCKET=lecrev-artifacts-276307603042-ap-south-1

# mTLS client credentials for the coordinator stream.
LECREV_ENABLE_MTLS=true
LECREV_GRPC_CA_CERT=/etc/lecrev/grpc/ca.pem
LECREV_GRPC_CLIENT_CERT=/etc/lecrev/grpc/client.pem
LECREV_GRPC_CLIENT_KEY=/etc/lecrev/grpc/client-key.pem
LECREV_GRPC_SERVER_NAME=lecrev-coordinator.internal

# Real execution plane settings.
LECREV_EXECUTION_DRIVER=firecracker
# For the current website-heavy production workload, prefer fewer larger microVMs.
LECREV_EXECUTION_HOST_SLOTS=2
LECREV_EXECUTION_HOST_FULL_NETWORK_SLOTS=2
LECREV_FIRECRACKER_VCPU_COUNT=4
LECREV_FIRECRACKER_BINARY=/usr/local/bin/firecracker
LECREV_JAILER_BINARY=/usr/local/bin/jailer
LECREV_FIRECRACKER_USE_JAILER=true
LECREV_FIRECRACKER_JAILER_USER=lecrev
LECREV_FIRECRACKER_KERNEL_IMAGE=/var/lib/lecrev/vmlinux
LECREV_FIRECRACKER_ROOTFS=/var/lib/lecrev/rootfs.ext4
LECREV_FIRECRACKER_WORKSPACE_DIR=/var/lib/lecrev/runtime
LECREV_FIRECRACKER_SNAPSHOT_DIR=/var/lib/lecrev/runtime/snapshots
LECREV_FIRECRACKER_CHROOT_BASE_DIR=/srv/jailer
LECREV_FIRECRACKER_GUEST_INIT=/usr/local/bin/lecrev-guest-runner

# Per-VM networking. The execution-host deploy provisions one tap device per
# full-network slot from this pool. Keep full-network slots less than or equal
# to both the tap count and the host vCPU count.
LECREV_FIRECRACKER_TAP_DEVICE_PREFIX=tap
LECREV_FIRECRACKER_TAP_COUNT=4
LECREV_FIRECRACKER_TAP_NETWORK_CIDR=172.16.0.0/24
LECREV_FIRECRACKER_TAP_SUBNET_PREFIX=30
