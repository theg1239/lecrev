server {
  listen 443 ssl;
  listen [::]:443 ssl;
  http2 on;
  server_name __FUNCTIONS_HOST__;

  gzip on;
  gzip_vary on;
  gzip_proxied any;
  gzip_comp_level 6;
  gzip_min_length 1024;
  gzip_types text/plain text/css text/html application/json application/javascript text/xml application/xml application/xml+rss text/javascript;

  ssl_certificate /etc/letsencrypt/live/__TLS_CERT_NAME__/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/__TLS_CERT_NAME__/privkey.pem;
  ssl_session_timeout 1d;
  ssl_session_cache shared:SSL:10m;
  ssl_protocols TLSv1.2 TLSv1.3;
  ssl_prefer_server_ciphers off;

  add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
  add_header X-Content-Type-Options nosniff;
  add_header X-Frame-Options SAMEORIGIN;
  add_header Referrer-Policy strict-origin-when-cross-origin;

  location /.well-known/acme-challenge/ {
    root __CERTBOT_WEBROOT__;
  }

  location / {
    proxy_pass http://127.0.0.1:8080;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Connection "te";
    proxy_set_header TE "trailers";
    proxy_pass_trailers on;
    proxy_buffering off;
    proxy_request_buffering off;
    add_header X-Accel-Buffering no;
  }
}
