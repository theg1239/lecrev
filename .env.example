LECREV_API_ADDR=:8080
LECREV_PUBLIC_BASE_URL=http://localhost:8080
LECREV_EXECUTION_REGIONS=ap-south-1,ap-south-2,ap-southeast-1
LECREV_POSTGRES_DSN=postgres://lecrev:lecrev@localhost:5432/lecrev?sslmode=disable
LECREV_NATS_URL=nats://localhost:4222
LECREV_ENABLE_MTLS=true
LECREV_EXECUTION_DRIVER=local-node
LECREV_FIRECRACKER_BINARY=/usr/local/bin/firecracker
LECREV_JAILER_BINARY=/usr/local/bin/jailer
LECREV_FIRECRACKER_USE_JAILER=false
LECREV_FIRECRACKER_KERNEL_IMAGE=
LECREV_FIRECRACKER_ROOTFS=
LECREV_FIRECRACKER_WORKSPACE_DIR=/var/lib/lecrev/runtime
LECREV_FIRECRACKER_SNAPSHOT_DIR=/var/lib/lecrev/runtime/snapshots
LECREV_FIRECRACKER_CHROOT_BASE_DIR=/var/lib/lecrev/jailer
LECREV_FIRECRACKER_GUEST_INIT=/usr/local/bin/lecrev-guest-runner
LECREV_FIRECRACKER_TAP_DEVICE=
LECREV_FIRECRACKER_GUEST_MAC=
LECREV_FIRECRACKER_GUEST_IP=
LECREV_FIRECRACKER_GATEWAY_IP=
LECREV_FIRECRACKER_NETMASK=
LECREV_FIRECRACKER_VCPU_COUNT=1
LECREV_FIRECRACKER_DEFAULT_MEMORY_MB=128
LECREV_S3_REGION=ap-south-1
LECREV_S3_ENDPOINT=http://localhost:9000
LECREV_S3_ACCESS_KEY=minioadmin
LECREV_S3_SECRET_KEY=minioadmin
LECREV_S3_BUCKET=lecrev-artifacts
LECREV_SECRETS_BACKEND=memory
LECREV_SECRETS_PROXY_TOKEN=dev-secrets-token
LECREV_AWS_REGION=ap-south-1
LECREV_AWS_ACCESS_KEY_ID=
LECREV_AWS_SECRET_ACCESS_KEY=
